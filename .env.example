# ==========================================
# Local development configuration
# Copy this file to .env before starting Compose. Every value labelled
# local-development-only must be replaced outside a developer workstation.
# ==========================================
SPRING_PROFILES_ACTIVE=dev

# ==========================================
# Database Configuration
# ==========================================
DB_NAME=userdb
DB_USERNAME=order_app
# Local development only. Replace in every shared or production environment.
DB_PASSWORD=local-dev-only-database-password

# ==========================================
# Redis Configuration
# ==========================================
# Local development only. Redis authentication is enabled by Compose.
REDIS_PASSWORD=local-dev-only-redis-password

# ==========================================
# Optional inspection-tool host ports
# ==========================================
# Optional `tools` profile (Kafka topic/event browser).
KAFKA_UI_PORT=8090
# Optional `observability` profile.
PROMETHEUS_PORT=9090

# ==========================================
# Service Ports (Local Development)
# ==========================================
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
STORE_SERVICE_PORT=8083
ORDER_SERVICE_PORT=8084
WEB_UI_SERVICE_PORT=8085
GATEWAY_SERVICE_PORT=8080
DISCOVERY_SERVICE_PORT=8761

# ==========================================
# JWT signing (local development only)
# Use a randomly generated value of at least 64 characters outside local dev.
# ==========================================
JWT_SECRET=local-dev-only-jwt-signing-key-change-me-0123456789-abcdefghijklmnopqrstuvwxyz

# ==========================================
# Internal Service API Keys
# (Must match between caller and callee)
# ==========================================
USER_SERVICE_INTERNAL_API_KEY=local-dev-only-user-service-api-key-change-me
STORE_SERVICE_INTERNAL_API_KEY=local-dev-only-store-service-api-key-change-me

# Browser session cookie. Set true behind HTTPS in production.
SESSION_COOKIE_SECURE=false

# Local UI behavior
THYMELEAF_CACHE=false
REGISTRATION_ENABLED=true
# Shows local-only persona credentials on the sign-in page.
DEMO_MODE=true

# ==========================================
# Event delivery and reconciliation tuning
# ==========================================
ORDER_PENDING_TIMEOUT=PT10M
ORDER_OUTBOX_MAX_ATTEMPTS=5
ORDER_OUTBOX_RETRY_BASE_DELAY=1000
ORDER_OUTBOX_RETRY_MAX_DELAY=60000
ORDER_OUTBOX_RETENTION=P30D
ORDER_INBOX_RETENTION=P30D
STORE_OUTBOX_MAX_ATTEMPTS=5
STORE_OUTBOX_RETRY_BASE_DELAY=1000
STORE_OUTBOX_RETRY_MAX_DELAY=60000
STORE_OUTBOX_RETENTION=P30D
STORE_INBOX_RETENTION=P30D
